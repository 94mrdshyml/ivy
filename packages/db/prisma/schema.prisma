generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  YOUTUBE
}

// ─── Core Models ─────────────────────────────────────────

model User {
  id        String    @id
  email     String    @unique
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships Membership[]
  auditLogs   AuditLog[]
}

model Organization {
  id        String    @id
  name      String
  slug      String    @unique
  plan      Plan      @default(FREE)
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members           Membership[]
  invitations       Invitation[]
  socialAccounts    SocialAccount[]
  instagramAccounts InstagramAccount[]
  auditLogs         AuditLog[]
}

model Membership {
  id        String    @id
  orgId     String
  userId    String
  role      Role      @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  org  Organization @relation(fields: [orgId], references: [id])
  user User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model Invitation {
  id        String           @id
  orgId     String
  email     String
  role      Role             @default(MEMBER)
  token     String           @unique
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  org Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([token])
}

model SocialAccount {
  id             String    @id
  orgId          String
  platform       Platform
  platformId     String
  handle         String
  accessToken    String
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  org              Organization      @relation(fields: [orgId], references: [id])
  instagramAccount InstagramAccount?

  @@unique([orgId, platform])
  @@index([orgId])
}

model InstagramAccount {
  id              String    @id
  orgId           String
  socialAccountId String    @unique
  igUserId        String    @unique
  handle          String
  name            String?
  profilePicUrl   String?
  followersCount  Int       @default(0)
  accessToken     String
  tokenExpiresAt  DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  org           Organization      @relation(fields: [orgId], references: [id])
  socialAccount SocialAccount     @relation(fields: [socialAccountId], references: [id])
  metrics       InstagramMetric[]
  posts         InstagramPost[]

  @@index([orgId])
}

model InstagramMetric {
  id                 String   @id
  orgId              String
  instagramAccountId String
  date               DateTime @db.Date
  followersCount     Int?
  impressions        Int?
  reach              Int?
  profileViews       Int?
  accountsEngaged    Int?
  websiteClicks      Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id])

  @@unique([instagramAccountId, date])
  @@index([orgId])
  @@index([instagramAccountId])
}

model InstagramPost {
  id                 String   @id
  orgId              String
  instagramAccountId String
  igMediaId          String   @unique
  mediaType          String
  caption            String?
  mediaUrl           String?
  thumbnailUrl       String?
  permalink          String?
  timestamp          DateTime
  likes              Int?
  comments           Int?
  shares             Int?
  saves              Int?
  reach              Int?
  impressions        Int?
  engagementRate     Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  instagramAccount InstagramAccount @relation(fields: [instagramAccountId], references: [id])

  @@index([orgId])
  @@index([instagramAccountId])
}

model AuditLog {
  id           String   @id
  orgId        String
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id])
  user User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
}
